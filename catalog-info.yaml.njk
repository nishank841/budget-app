apiVersion: backstage.io/v1alpha1
kind: Component
metadata:
  name: ${{ values.name }}
  annotations:
    # Remove the source-location and techdocs-ref none
    # Let the GitHub integration handle the 'View Source' button automatically
  links:
    - url: ${{ values.confluenceUrl }}
      title: "Documentation"
      icon: docs
spec:
  type: service
  lifecycle: experimental
  owner: group:default/guests
