apiVersion: backstage.io/v1alpha1
kind: Component
metadata:
  name: ${{ values.name | dump }}
  annotations:
    # This is what the code above uses to know where to redirect
    backstage.io/view-url: ${{ values.confluenceUrl | dump }}
    
    # We add this just to make sure the "Docs" tab is NOT greyed out
    backstage.io/techdocs-ref: url:${{ values.confluenceUrl | dump }} 
spec:
  type: service
  lifecycle: experimental
  owner: group:default/guests
