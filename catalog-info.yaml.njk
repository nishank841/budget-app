apiVersion: backstage.io/v1alpha1
kind: Component
metadata:
  name: ${{ values.name }}
  annotations:
    # This line places the link beside "VIEW SOURCE" in the About card
    backstage.io/view-url: ${{ values.confluenceUrl | dump }}  
  links:
    - url: ${{ values.confluenceUrl }}
      title: "Documentation"
      icon: docs
spec:
  type: service
  lifecycle: experimental
  owner: group:default/guests
